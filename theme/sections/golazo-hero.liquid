{%- liquid
  assign hero_collection = section.settings.collection
  assign hero_image = section.settings.image

  if hero_image == blank and hero_collection != blank
    for p in hero_collection.products limit: 1
      assign hero_image = p.featured_image
    endfor
  endif

  if hero_image == blank
    assign hero_image = collections.all.products.first.featured_image
  endif

  assign cta_url = section.settings.button_link
  if cta_url == blank and hero_collection != blank
    assign cta_url = hero_collection.url
  endif
  if cta_url == blank
    assign cta_url = routes.all_products_collection_url
  endif

  assign hero_pt = section.settings['padding-block-start'] | default: 56
  assign hero_pb = section.settings['padding-block-end'] | default: 56
-%}

<div class="golazo-hero" style="--golazo-hero-pt: {{ hero_pt }}px; --golazo-hero-pb: {{ hero_pb }}px;">
  <div class="golazo-hero__inner">
    <div class="golazo-hero__content">
      {%- if section.settings.eyebrow != blank -%}
        <p class="golazo-hero__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h1 class="golazo-hero__title">{{ section.settings.heading }}</h1>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="golazo-hero__sub">{{ section.settings.subheading }}</p>
      {%- endif -%}
      {%- if section.settings.button_label != blank -%}
        <a class="golazo-hero__cta button" href="{{ cta_url }}">{{ section.settings.button_label }}</a>
      {%- endif -%}
    </div>

    {%- if hero_image != blank -%}
      <div class="golazo-hero__media">
        <img
          src="{{ hero_image | image_url: width: 1100 }}"
          srcset="{{ hero_image | image_url: width: 550 }} 550w, {{ hero_image | image_url: width: 1100 }} 1100w"
          sizes="(min-width: 750px) 48vw, 100vw"
          alt="{{ hero_image.alt | escape }}"
          width="1100"
          height="{{ 1100 | divided_by: hero_image.aspect_ratio | round }}"
          loading="eager"
          fetchpriority="high"
        >
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "GOLAZO hero",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "2026 World Cup Collection"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "World Cup 26"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Authentic national-team jerseys. Engineered for the pitch, built for the streets."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop the collection"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Featured collection",
      "info": "Used for the hero image and button link when set."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image",
      "info": "Optional. Overrides the collection image."
    },
    {
      "type": "header",
      "content": "Section spacing"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 56
    }
  ],
  "presets": [
    {
      "name": "GOLAZO hero"
    }
  ]
}
{% endschema %}

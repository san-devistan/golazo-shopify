{%- doc -%}
  Renders the GOLAZO wishlist heart (outline + filled states).
  Toggle the filled state by adding the `is-liked` class to the button (handled by golazo-wishlist.js).

  @example
  {% render 'golazo-heart' %}
{%- enddoc -%}
<svg class="golazo-heart golazo-heart--outline" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="none" focusable="false" aria-hidden="true">

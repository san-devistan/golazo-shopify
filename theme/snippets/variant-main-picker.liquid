{%- doc -%}
  Renders a default variant picker, used to display the variant picker in the variants block.

  @param {object} product_resource - The product object.
  @param {object} [block] - The block object
  @param {object} section - The section object.
  @param {object} product - The current product object (used to determine selected variant state).
{%- enddoc -%}

{% assign block_settings = block.settings %}

<script
  src="{{ 'dialog.js' | asset_url }}"
  type="module"
></script>

{% liquid
  # Custom styling applies to:
  #   - dropdowns + buttons when variant_style_class == 'custom' (unselected colors)
  #   - buttons only when selected_variant_style_class == 'custom' (selected colors)
  # The 'buttons' label is kept for backwards-compat of the class name.
  assign has_custom_variant_buttons = false
  if block_settings.variant_style_class == 'custom'
    assign has_custom_variant_buttons = true
  endif
  if block_settings.variant_style == 'buttons' and block_settings.selected_variant_style_class == 'custom'
    assign has_custom_variant_buttons = true
  endif
  assign fieldset_index = 0
%}

{% unless product_resource.has_only_default_variant %}
  {% if has_custom_variant_buttons %}
    {% render 'variant-button-custom-styles', block_settings: block_settings, block_id: block.id %}
  {% endif %}
  <variant-picker
    class="variant-picker spacing-style variant-picker--{{ block_settings.alignment }}{% if has_custom_variant_buttons %} variant-picker--custom-{{ block.id }}{% endif %}"
    style="
      {% render 'spacing-style', settings: block_settings %}
       {% if block_settings.option_label_text_color != blank %}
        --variant-option-label-color: rgba({{ block_settings.option_label_text_color.rgba }});
        --variant-option-label-color-subdued: rgba({{ block_settings.option_label_text_color.rgb }} / var(--opacity-subdued-text));
      {% endif %}
    "
    data-section-id="{{ section.id }}"
    data-product-id="{{ product_resource.id }}"
    data-product-handle="{{ product_resource.handle }}"
    data-product-title="{{ product_resource.title | escape }}"
    data-block-id="{{ block.id }}"
    data-product-url="{{ product_resource.url }}"
    ref="mainVariantPicker"
    {% if product.id == product_resource.id %}
      data-template-product-match="true"
    {% endif %}
    {{ block.shopify_attributes }}
    {% if request.visual_preview_mode %}
      data-shopify-visual-preview
    {% endif %}
  >
    <form class="variant-picker__form">
      {%- for product_option in product_resource.options_with_values -%}
        {%- liquid
          assign swatch_count = product_option.values | map: 'swatch' | compact | size
          assign variant_style = block_settings.variant_style
          assign option_name_downcase = product_option.name | downcase
          assign show_size_guide = false

          if option_name_downcase contains 'size'
            assign show_size_guide = true
          endif

          if swatch_count > 0 and block_settings.show_swatches
            if block_settings.variant_style == 'dropdown'
              assign variant_style = 'swatch_dropdown'
            else
              assign variant_style = 'swatch'
            endif
          endif

          if variant_style == 'buttons' and settings.variant_button_width == 'equal-width-buttons'
            assign fieldset_id = section.id | append: '-' | append: product_resource.id | append: '-' | append: product_option.name | handleize
            assign option_id_attribute = 'data-option-id="' | append: fieldset_id | append: '"'
            assign longest_value = 0
          endif

          assign size_guide_id = ''
          if show_size_guide
            assign size_guide_id = 'SizeGuide-' | append: section.id | append: '-' | append: block.id | append: '-' | append: fieldset_index
          endif
        -%}

        {%- if product_option.values.size == 1 and variant_style != 'swatch' -%}
          <div
            class="variant-option"
            data-testid="variant-option-single"
          >
            {{- product_option.name | escape -}}
            <span
              class="variant-option__swatch-value"
              data-testid="variant-option-single-value"
            >
              {{- product_option.selected_value -}}
            </span>
          </div>
        {%- elsif variant_style == 'swatch' or block_settings.variant_style == 'buttons' -%}
          <fieldset
            class="variant-option variant-option--buttons{% if variant_style == 'swatch' %} variant-option--swatches{% else %} variant-option--{{ settings.variant_button_width }}{% endif %}"
            data-fieldset-index="{{ fieldset_index }}"
            ref="fieldsets[]"
            {{ option_id_attribute }}
          >
            <legend{% if show_size_guide %} class="variant-option__legend variant-option__legend--size-guide"{% endif %}>
              {%- if show_size_guide -%}
                <span class="variant-option__legend-text">
              {%- endif -%}
                {{ product_option.name | escape -}}
                {%- if variant_style == 'swatch' -%}
                  <span class="variant-option__swatch-value">{{ product_option.selected_value }}</span>
                {%- endif %}
              {%- if show_size_guide -%}
                </span>
                <button
                  type="button"
                  class="button-unstyled size-guide__trigger"
                  data-size-guide-open
                  aria-haspopup="dialog"
                  aria-controls="{{ size_guide_id }}"
                >
                  {{ 'content.size_guide_trigger' | t }}
                </button>
              {%- endif %}
            </legend>
            {%- if show_size_guide -%}
              <dialog-component
                class="size-guide"
                data-size-guide
                data-size-guide-unit="metric"
              >
                <dialog
                  id="{{ size_guide_id }}"
                  ref="dialog"
                  class="size-guide__dialog dialog-modal"
                  scroll-lock
                  aria-labelledby="{{ size_guide_id }}-heading"
                >
                  <div class="size-guide__header">
                    <h2
                      id="{{ size_guide_id }}-heading"
                      class="size-guide__title"
                    >
                      {{ 'content.size_guide' | t }}
                    </h2>
                    <div
                      class="size-guide__units"
                      role="group"
                      aria-label="{{ 'content.size_guide_units' | t }}"
                    >
                      <button
                        type="button"
                        class="button-unstyled size-guide__unit-button"
                        data-size-guide-unit-button="metric"
                        aria-pressed="true"
                      >
                        {{ 'content.metric' | t }}
                      </button>
                      <button
                        type="button"
                        class="button-unstyled size-guide__unit-button"
                        data-size-guide-unit-button="imperial"
                        aria-pressed="false"
                      >
                        {{ 'content.us_uk' | t }}
                      </button>
                    </div>
                  </div>
                  <div class="size-guide__table-wrapper">
                    <table class="size-guide__table">
                      <thead>
                        <tr>
                          <th scope="col">{{ 'content.size' | t }}</th>
                          <th
                            scope="col"
                            class="size-guide__cell--metric"
                          >
                            {{ 'content.height_with_unit' | t: unit: 'cm' }}
                          </th>
                          <th
                            scope="col"
                            class="size-guide__cell--metric"
                          >
                            {{ 'content.weight_with_unit' | t: unit: 'kg' }}
                          </th>
                          <th
                            scope="col"
                            class="size-guide__cell--imperial"
                          >
                            {{ 'content.height_with_unit' | t: unit: 'ft/in' }}
                          </th>
                          <th
                            scope="col"
                            class="size-guide__cell--imperial"
                          >
                            {{ 'content.weight_with_unit' | t: unit: 'lb' }}
                          </th>
                        </tr>
                      </thead>
                      <tbody>
                        <tr>
                          <th scope="row">S</th>
                          <td class="size-guide__cell--metric">160-165</td>
                          <td class="size-guide__cell--metric">50-62</td>
                          <td class="size-guide__cell--imperial">5'3"-5'5"</td>
                          <td class="size-guide__cell--imperial">110-137</td>
                        </tr>
                        <tr>
                          <th scope="row">M</th>
                          <td class="size-guide__cell--metric">165-170</td>
                          <td class="size-guide__cell--metric">62-75</td>
                          <td class="size-guide__cell--imperial">5'5"-5'7"</td>
                          <td class="size-guide__cell--imperial">137-165</td>
                        </tr>
                        <tr>
                          <th scope="row">L</th>
                          <td class="size-guide__cell--metric">170-175</td>
                          <td class="size-guide__cell--metric">75-80</td>
                          <td class="size-guide__cell--imperial">5'7"-5'9"</td>
                          <td class="size-guide__cell--imperial">165-176</td>
                        </tr>
                        <tr>
                          <th scope="row">XL</th>
                          <td class="size-guide__cell--metric">175-180</td>
                          <td class="size-guide__cell--metric">80-85</td>
                          <td class="size-guide__cell--imperial">5'9"-5'11"</td>
                          <td class="size-guide__cell--imperial">176-187</td>
                        </tr>
                        <tr>
                          <th scope="row">XXL</th>
                          <td class="size-guide__cell--metric">180-185</td>
                          <td class="size-guide__cell--metric">85-90</td>
                          <td class="size-guide__cell--imperial">5'11"-6'1"</td>
                          <td class="size-guide__cell--imperial">187-198</td>
                        </tr>
                      </tbody>
                    </table>
                  </div>
                  <button
                    ref="closeButton"
                    type="button"
                    on:click="/closeDialog"
                    class="button button-unstyled close-button size-guide__close"
                    aria-label="{{ 'accessibility.close_dialog' | t }}"
                  >
                    {{- 'icon-close.svg' | inline_asset_content -}}
                  </button>
                </dialog>
              </dialog-component>
            {%- endif -%}
            {%- for product_option_value in product_option.values -%}
              {% if product_option_value.size > longest_value and option_id_attribute %}
                {% assign longest_value = product_option_value.size %}
              {% endif %}
              <label
                class="variant-option__button-label{% if variant_style == 'swatch' %} variant-option__button-label--has-swatch{% endif %}"
              >
                <input
                  type="radio"
                  name="{{ product_option.name | escape }}-{{ block.id }}-{{ product_resource.id }}"
                  value="{{ product_option_value | escape }}"
                  aria-label="{{ product_option_value.name | escape }}{% if product_option_value.available == false %} - {{ 'products.product.sold_out' | t }}{% endif %}"
                  {% if product_option_value.available == false %}
                    aria-disabled="true"
                  {% endif %}
                  data-previous-checked="false"
                  data-fieldset-index="{{ fieldset_index }}"
                  data-input-index="{{ forloop.index0 }}"
                  data-input-id="{{ product_option.position }}-{{ forloop.index0 }}"
                  data-option-name="{{ product_option.name | escape }}"
                  data-option-value-id="{{ product_option_value.id }}"
                  data-option-available="{{ product_option_value.available }}"
                  data-connected-product-url="{{ product_option_value.product_url }}"
                  {% if product_option_value.variant.id %}
                    data-variant-id="{{ product_option_value.variant.id }}"
                  {% endif %}
                  {% if product_option_value.selected %}
                    data-current-checked="true"
                    checked
                  {% else %}
                    data-current-checked="false"
                  {% endif %}
                >
                {% if variant_style == 'swatch' %}
                  {% liquid
                    assign featured_media = product_option_value.variant.featured_media

                    # If the variant has no featured media, and we have a combined listing product, then fall back to
                    # using the featured media of the child product that is linked to this option value.
                    if featured_media == blank and product_option_value.product_url
                      assign featured_media = product_option_value.variant.product.featured_media
                    endif
                  %}

                  {% render 'swatch',
                    swatch: product_option_value.swatch,
                    variant_image: featured_media,
                    mode: 'unscaled'
                  %}
                {% else %}
                  {% if product_option_value.available == true %}
                    <span
                      class="variant-option__button-label__pill"
                      data-key="variant-option-pill"
                    ></span>
                  {% endif %}
                  <span
                    class="variant-option__button-label__text"
                    data-key="variant-option-text"
                  >
                    {{- product_option_value | escape -}}
                  </span>
                {% endif %}
                {% render 'strikethrough-variant', product_option: product_option_value %}
              </label>
            {%- endfor -%}
            {% if option_id_attribute %}
              {% style %}
                [data-option-id="{{ fieldset_id }}"] {
                  --variant-ch: {{ longest_value | times: 0.65 }}em;
                }
              {% endstyle %}
            {% endif %}
          </fieldset>
          {%- assign fieldset_index = fieldset_index | plus: 1 -%}
        {%- elsif block_settings.variant_style == 'dropdowns' -%}
          {%
            # There is an opportunity to build a custom select component that will allow us to style the select element further (animation for dropdown, swatches shown in the dropdown options, etc)
            # It's too bad as it mean rebuilding baked in behaviours but I think we've already done that for the locale selectors
            # in dawn. So it might mean more time spent in setting it up but worth it for future updates/styling.
          %}
          {% liquid
            assign property_being_updated = false
            if settings.variant_swatch_width != settings.variant_swatch_height
              assign property_being_updated = true
              # (original width / original height) x new height (20px at the moment) = new width
              assign new_width = settings.variant_swatch_width | times: 1.0 | divided_by: settings.variant_swatch_height | times: 20
            endif
          %}

          <div class="variant-option variant-option--dropdowns">
            <label for="Option-{{ block.id }}-{{ forloop.index0 }}">{{ product_option.name | escape }}</label>
            <div
              class="variant-option__select-wrapper"
              style="
                {%- if property_being_updated  -%}
                  --variant-picker-swatch-width: clamp(10px,{{ new_width }}px, 50px);
                {%- endif -%}
              "
            >
              <select
                id="Option-{{ block.id }}-{{ forloop.index0 }}"
                name="options[{{ product_option.name | escape }}]"
                class="variant-option__select"
              >
                {%- for product_option_value in product_option.values -%}
                  <option
                    value="{{ product_option_value | escape }}"
                    data-input-id="{{ product_option.position }}-{{ forloop.index0 }}"
                    data-option-name="{{ product_option.name | escape }}"
                    data-option-value-id="{{ product_option_value.id }}"
                    data-variant-id="{{ product_option_value.variant.id }}"
                    data-connected-product-url="{{ product_option_value.product_url }}"
                    {% if product_option_value.selected %}
                      selected="selected"
                    {% endif %}
                  >
                    {% if product_option_value.available == false %}
                      {{ product_option_value | escape }} - {{ 'content.unavailable' | t }}
                    {% else %}
                      {{ product_option_value | escape }}
                    {% endif %}
                  </option>
                {%- endfor -%}
              </select>
              <svg
                aria-hidden="true"
                focusable="false"
                class="icon icon-caret"
                viewBox="0 0 10 6"
              >
                {%- render 'icon', icon: 'caret' -%}
              </svg>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}

      <script type="application/json">
        {{ product_resource.selected_or_first_available_variant | json }}
      </script>
    </form>
  </variant-picker>
{% endunless %}

{% stylesheet %}
  .variant-option__legend--size-guide {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--gap-md);
    width: 100%;
  }

  .variant-option__legend-text {
    min-width: 0;
  }

  .size-guide__trigger {
    color: currentColor;
    cursor: pointer;
    font: inherit;
    text-decoration: underline;
    text-underline-offset: 0.18em;
    white-space: nowrap;
  }

  .size-guide__trigger:hover {
    opacity: 0.65;
  }

  .size-guide {
    display: contents;
  }

  .size-guide__dialog {
    inset: 0;
    position: fixed;
    width: min(560px, calc(100vw - 32px));
    max-width: min(560px, calc(100vw - 32px));
    max-height: calc(100dvh - 32px);
    margin: auto;
    padding: var(--padding-4xl) var(--padding-xl) var(--padding-xl);
    overflow: auto;
  }

  .size-guide__dialog.dialog-modal[open] {
    animation: sizeGuideFadeIn var(--animation-speed) var(--animation-easing) forwards;
  }

  .size-guide__dialog.dialog-modal.dialog-closing {
    animation: sizeGuideFadeOut var(--animation-speed) var(--animation-easing) forwards;
  }

  .size-guide__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--gap-md);
    margin-block-end: var(--margin-lg);
  }

  .size-guide__close.close-button {
    position: absolute;
    inset-block-start: var(--padding-md);
    inset-inline-end: var(--padding-md);
  }

  .size-guide__title {
    margin: 0;
    min-width: 0;
    font-size: var(--font-size--xl);
  }

  .size-guide__units {
    display: inline-flex;
    flex: 0 0 auto;
    gap: 0;
    border: 1px solid currentColor;
  }

  .size-guide__unit-button {
    padding: 0.5rem 0.85rem;
    color: currentColor;
    cursor: pointer;
    font: inherit;
    line-height: 1;
  }

  .size-guide__unit-button + .size-guide__unit-button {
    border-inline-start: 1px solid currentColor;
  }

  .size-guide__unit-button[aria-pressed='true'] {
    background: var(--color-foreground);
    color: var(--color-background);
  }

  .size-guide__table-wrapper {
    width: 100%;
    overflow-x: auto;
  }

  .size-guide__table {
    width: 100%;
    border-collapse: collapse;
    text-align: left;
  }

  .size-guide__table th,
  .size-guide__table td {
    padding: 0.8rem 0.75rem;
    border-block-end: 1px solid rgb(var(--color-foreground-rgb) / var(--opacity-15));
    white-space: nowrap;
  }

  .size-guide__table thead th {
    font-weight: 700;
  }

  .size-guide__table tbody th {
    font-weight: 700;
  }

  .size-guide__cell--imperial {
    display: none;
  }

  .size-guide[data-size-guide-unit='imperial'] .size-guide__cell--metric {
    display: none;
  }

  .size-guide[data-size-guide-unit='imperial'] .size-guide__cell--imperial {
    display: table-cell;
  }

  @keyframes sizeGuideFadeIn {
    from {
      opacity: 0;
      transform: scale(0.98);
    }

    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  @keyframes sizeGuideFadeOut {
    from {
      opacity: 1;
      transform: scale(1);
    }

    to {
      opacity: 0;
      transform: scale(0.98);
    }
  }

  @media screen and (max-width: 749px) {
    .size-guide__dialog {
      width: calc(100dvw - 32px);
      max-width: calc(100dvw - 32px);
      height: auto;
      max-height: calc(100dvh - 32px);
      padding: var(--padding-4xl) var(--padding-md) var(--padding-md);
    }
  }
{% endstylesheet %}

{% javascript %}
  if (!window.variantSizeGuideInitialized) {
    window.variantSizeGuideInitialized = true;

    document.addEventListener('click', (event) => {
      if (!(event.target instanceof Element)) return;

      const trigger = event.target.closest('[data-size-guide-open]');
      if (trigger) {
        event.preventDefault();

        const component = trigger.closest('.variant-option')?.querySelector('[data-size-guide]');
        if (!(component instanceof HTMLElement)) return;

        customElements.upgrade(component);

        if (typeof component.showDialog === 'function') {
          component.showDialog();
        }

        return;
      }

      const unitButton = event.target.closest('[data-size-guide-unit-button]');
      if (!unitButton) return;

      const component = unitButton.closest('[data-size-guide]');
      const unit = unitButton.getAttribute('data-size-guide-unit-button');
      if (!(component instanceof HTMLElement) || !unit) return;

      component.setAttribute('data-size-guide-unit', unit);

      component.querySelectorAll('[data-size-guide-unit-button]').forEach((button) => {
        button.setAttribute('aria-pressed', String(button === unitButton));
      });
    });
  }
{% endjavascript %}

{% render 'variant-picker-styles' %}
